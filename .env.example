# Indexer (service_role for full write access)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key
MISTRAL_API_KEY=your-mistral-api-key

# MCP Server (anon key + project token for scoped read access)
# These are passed via `claude mcp add --env` per project, not stored here.
# SUPABASE_ANON_KEY=your-anon-key
# PROJECT_TOKEN=your-project-uuid-token
